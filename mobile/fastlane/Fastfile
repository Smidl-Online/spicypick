default_platform(:ios)

# ─── iOS ──────────────────────────────────────────────────────────────────────
platform :ios do
  desc "Upload metadata to App Store Connect"
  lane :metadata do
    deliver(
      skip_binary_upload: true,
      skip_screenshots: false,
      metadata_path: "./fastlane/metadata/ios",
      screenshots_path: "./fastlane/screenshots/ios",
      force: true,
      precheck_include_in_app_purchases: false
    )
  end

  desc "Upload screenshots only to App Store Connect"
  lane :screenshots do
    deliver(
      skip_binary_upload: true,
      skip_metadata: true,
      screenshots_path: "./fastlane/screenshots/ios",
      force: true
    )
  end

  desc "Generate screenshots via Maestro (requires running iOS simulator + Maestro CLI)"
  lane :capture_screenshots do
    # Regenerate designed placeholder screenshots via Python script
    sh("python3 ../scripts/generate-screenshots.py")
    UI.success("Screenshots generated in fastlane/screenshots/ios/")
    UI.message("To capture real device screenshots, run: maestro test ../e2e/screenshots.yaml")
    UI.message("Then copy ~/.maestro/tests/<run-id>/screenshots/ into fastlane/screenshots/ios/en-US/")
  end
end

# ─── Android ──────────────────────────────────────────────────────────────────
platform :android do
  desc "Upload metadata to Google Play"
  lane :metadata do
    upload_to_play_store(
      skip_upload_apk: true,
      skip_upload_aab: true,
      skip_upload_changelogs: false,
      metadata_path: "./fastlane/metadata/android"
    )
  end

  desc "Upload screenshots only to Google Play"
  lane :screenshots do
    upload_to_play_store(
      skip_upload_apk: true,
      skip_upload_aab: true,
      skip_upload_changelogs: true,
      skip_upload_metadata: true,
      skip_upload_images: false,
      metadata_path: "./fastlane/metadata/android"
    )
  end

  desc "Generate screenshots via Maestro (requires running Android emulator + Maestro CLI)"
  lane :capture_screenshots do
    sh("python3 ../scripts/generate-screenshots.py")
    UI.success("Screenshots generated in fastlane/screenshots/android/")
    UI.message("To capture real device screenshots, run: maestro test ../e2e/screenshots.yaml")
    UI.message("Then copy ~/.maestro/tests/<run-id>/screenshots/ into fastlane/screenshots/android/en-US/phoneScreenshots/")
  end
end

# ─── Shared ───────────────────────────────────────────────────────────────────
desc "Regenerate all placeholder screenshots (iOS + Android)"
lane :generate_screenshots do
  sh("python3 ../scripts/generate-screenshots.py")
  UI.success("All placeholder screenshots generated.")
end
