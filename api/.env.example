DATABASE_URL=postgresql://spicypick:password@localhost:5432/spicypick
JWT_SECRET=your-jwt-secret-here
JWT_REFRESH_SECRET=your-jwt-refresh-secret-here
ADMIN_TOKEN=your-admin-token-here
AI_API_KEY=your-ai-api-key-here
# Optional: OpenAI and Google AI keys for multi-provider support
OPENAI_API_KEY=
GOOGLE_AI_API_KEY=
# Optional: per-use-case model overrides (defaults: claude-haiku-4-5-20251001 / claude-haiku-4-5-20251001 / claude-sonnet-4-6-20250514)
AI_MODEL_SCENARIO=
AI_MODEL_MODERATION=
AI_MODEL_EXPERT=
RESEND_API_KEY=your-resend-api-key-here
REVENUECAT_API_KEY=your-revenuecat-server-api-key-here
# Mobile RevenueCat SDK keys (set in mobile/app.json extra)
# REVENUECAT_IOS_KEY=your-revenuecat-ios-public-key
# REVENUECAT_ANDROID_KEY=your-revenuecat-android-public-key
SENTRY_DSN=
POSTHOG_API_KEY=
POSTHOG_HOST=https://eu.i.posthog.com
APP_URL=https://spicypick.app
ANDROID_SHA256_FINGERPRINT=your-android-sha256-fingerprint-here
APPLE_TEAM_ID=your-apple-team-id-here
CORS_ORIGIN=*
PORT=3000
NODE_ENV=development

# ── Database Backup ─────────────────────────────────────────────────────────
# Hetzner Object Storage (S3-compatible) — create bucket at console.hetzner.com
BACKUP_S3_BUCKET=spicypick-backups
BACKUP_S3_ACCESS_KEY=your-hetzner-s3-access-key
BACKUP_S3_SECRET_KEY=your-hetzner-s3-secret-key
BACKUP_S3_ENDPOINT=https://fsn1.your-objectstorage.com
# How many days to keep backups (default: 30)
BACKUP_RETENTION_DAYS=30
# Email for backup failure notifications (uses RESEND_API_KEY above)
BACKUP_NOTIFY_EMAIL=jan@smidl.online
FROM_EMAIL=backup@spicypick.app
